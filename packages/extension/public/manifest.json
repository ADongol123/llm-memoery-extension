{
  "manifest_version": 3,
  "name": "LLM Memory",
  "version": "4.0.0",
  "description": "Your conversations across Claude, ChatGPT, Grok, Gemini and DeepSeek — in one place. Generate Context Packages and continue any conversation on any AI.",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webNavigation",
    "alarms",
    "commands",
    "identity"
  ],

  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://grok.com/*",
    "https://chat.deepseek.com/*",
    "https://*.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "LLM Memory"
  },

  "commands": {
    "save-conversation": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current conversation"
    },
    "open-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open LLM Memory"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "externally_connectable": {
    "matches": [
      "https://llmmemory.app/*",
      "http://localhost:3000/*"
    ]
  }
}
