{
  "manifest_version": 3,
  "name": "Stash",
  "version": "4.0.0",
  "description": "Your conversations across Claude, ChatGPT, Gemini, Grok, DeepSeek, Perplexity, Copilot, Mistral, Meta AI and Poe — in one place. Inject relevant context into any new chat.",

  "permissions": [
    "storage",
    "tabs",
    "windows",
    "scripting",
    "webNavigation",
    "alarms",
    "commands",
    "identity"
  ],

  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://grok.com/*",
    "https://chat.deepseek.com/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/chat*",
    "https://chat.mistral.ai/*",
    "https://meta.ai/*",
    "https://www.meta.ai/*",
    "https://poe.com/*",
    "https://*.supabase.co/*",
    "https://huggingface.co/*",
    "https://api-inference.huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cdn-lfs-us-1.huggingface.co/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Stash",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },

  "commands": {
    "save-conversation": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current conversation"
    },
    "open-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open Stash"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*",
        "https://chat.deepseek.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://poe.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "externally_connectable": {
    "matches": [
      "https://llmmemory.app/*",
      "http://localhost:3000/*"
    ]
  }
}
