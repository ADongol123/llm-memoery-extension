# Copy this to .env and fill in your values

# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# URL of your deployed get-selectors Edge Function
# e.g. https://your-project-ref.supabase.co/functions/v1/get-selectors
SELECTORS_URL=https://your-project-ref.supabase.co/functions/v1/get-selectors

# Web app (same values, prefixed for Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# These go in your Supabase Edge Functions secrets (NOT here)
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   (auto-set by Supabase Edge runtime)
